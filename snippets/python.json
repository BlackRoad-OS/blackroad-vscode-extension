{
  "BlackRoad Client Init": {
    "prefix": "br-init",
    "body": [
      "from blackroad import BlackRoadClient",
      "",
      "client = BlackRoadClient(api_key='${1:your-api-key}')"
    ],
    "description": "Initialize BlackRoad client"
  },
  "BlackRoad List Agents": {
    "prefix": "br-agents-list",
    "body": [
      "agents = client.agents.list(division='${1:AI}', level=${2:4})",
      "print(f'Found {len(agents)} agents')"
    ],
    "description": "List BlackRoad agents"
  },
  "BlackRoad Register Agent": {
    "prefix": "br-agent-register",
    "body": [
      "agent = client.agents.register(",
      "    name='${1:my-agent}',",
      "    agent_type='${2:ai}',",
      "    division='${3:Labs}',",
      "    level=${4:4},",
      ")"
    ],
    "description": "Register a new BlackRoad agent"
  },
  "BlackRoad Dispatch Task": {
    "prefix": "br-task-dispatch",
    "body": [
      "task = client.tasks.dispatch(",
      "    title='${1:Task title}',",
      "    description='${2:Task description}',",
      "    priority='${3:high}',",
      "    division='${4:Security}',",
      ")",
      "print(f'Created task: {task[\"id\"]}')"
    ],
    "description": "Dispatch a new BlackRoad task"
  },
  "BlackRoad Complete Task": {
    "prefix": "br-task-complete",
    "body": [
      "client.tasks.complete('${1:task-id}', result='${2:Successfully completed}')"
    ],
    "description": "Complete a BlackRoad task"
  },
  "BlackRoad Log Memory": {
    "prefix": "br-memory-log",
    "body": [
      "entry = client.memory.log(",
      "    action='${1:deployed}',",
      "    entity='${2:service-name}',",
      "    details='${3:Details about the action}',",
      "    tags=['${4:tag1}', '${5:tag2}'],",
      ")"
    ],
    "description": "Log entry to BlackRoad memory"
  },
  "BlackRoad Query Memory": {
    "prefix": "br-memory-query",
    "body": [
      "entries = client.memory.query(",
      "    search='${1:deployment}',",
      "    action='${2:deployed}',",
      "    limit=${3:50},",
      ")"
    ],
    "description": "Query BlackRoad memory"
  },
  "BlackRoad TIL": {
    "prefix": "br-til",
    "body": [
      "client.memory.til('${1:category}', '${2:What I learned today}')"
    ],
    "description": "Share a Today I Learned entry"
  },
  "BlackRoad Error Handling": {
    "prefix": "br-try-except",
    "body": [
      "from blackroad import NotFoundError, RateLimitError, AuthenticationError",
      "",
      "try:",
      "    ${1:# Your BlackRoad API call}",
      "except NotFoundError:",
      "    print('Resource not found')",
      "except RateLimitError as e:",
      "    print(f'Rate limited. Retry after {e.retry_after}s')",
      "except AuthenticationError:",
      "    print('Invalid API key')"
    ],
    "description": "BlackRoad error handling pattern"
  }
}
